display("even(10):");
display(even(10));

display("odd(11):");
display(odd(11));

display("factorial(6):");
display(factorial(6));

display("prime(29):");
display(prime(29));

display("palindrome(level):");
display(palindrome("level"));

display("leap_year(2024):");
display(leap_year(2024));

display("power(3, 4):");
display(power(3, 4));

dec angle = 30;
display("sin(30):");
display(sin(angle));
display("cos(30):");
display(cos(angle));
display("tan(30):");
display(tan(angle));
